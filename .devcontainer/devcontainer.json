{
  "name": "DataConsumer, TimescaleDB Dev e NATS JetStream",
  "dockerComposeFile": "docker-compose.yml",
  "service": "data-consumer",
  "runServices": [
    "data-consumer",
    "timescale",
    "nats"
  ],
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces",
  "forwardPorts": [
    4222,
    5432
  ],
  "portsAttributes": {
    "4222": {
      "label": "NATS"
    },
    "5432": {
      "label": "TimescaleDB"
    }
  },
  "postCreateCommand": "bash .devcontainer/init.sh",
  "postStartCommand": "bash .devcontainer/ensure-nats-stream.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "go.lintTool": "golangci-lint",
        "go.useLanguageServer": true,
        "go.formatTool": "gofumpt",
        "go.toolsManagement.autoUpdate": false,
        "go.alternateTools": {
          "golangci-lint": "/usr/local/bin/golangci-lint",
          "gofumpt": "/home/vscode/go/bin/gofumpt",
          "gopls": "/home/vscode/go/bin/gopls",
          "dlv": "/home/vscode/go/bin/dlv"
        }
      },
      "extensions": [
        "golang.go",
        "ms-ossdata.vscode-postgresql"
      ]
    }
  }
}